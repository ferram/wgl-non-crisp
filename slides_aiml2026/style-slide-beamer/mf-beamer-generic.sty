\setbeamersize{text margin left=1em,text margin right=1.5em}
 \setlength{\leftmargini}{1.5\beamer@leftmargin}
 \setlength{\leftmarginii}{\beamer@leftmargin}
 \setlength{\leftmarginiii}{\beamer@leftmargin}
% \mode<all>


\setbeamertemplate{section page}
{
    \begin{centering}
    \begin{beamercolorbox}[sep=12pt,center]{part title}
    \usebeamerfont{section title}\insertsection\par
    \end{beamercolorbox}
    \end{centering}
}


\makeatletter
\AtBeginPart{%
  \addtocontents{toc}{\protect\beamer@partintoc{\the\c@part}{\beamer@partnameshort}{\the\c@page}}%
}
%% number, shortname, page.
\providecommand\beamer@partintoc[3]{%
  \ifnum\c@tocdepth=-1\relax
  % requesting onlyparts.
  \makebox[3em][r]{#1~}--{~\blue #2}
  \par
  \fi
}
\define@key{beamertoc}{onlyparts}[]{%
  \c@tocdepth=-1\relax
}
\makeatother%


\setbeamerfont*{itemize/enumerate body}{size=\normalsize}
\setbeamerfont*{itemize/enumerate subbody}{parent=itemize/enumerate body}

