\mode<presentation>
{ 
  %% BLOCCHI colorati
  \setbeamercolor{blue2 head}{fg=white, bg=blue!300} %
  \setbeamercolor{blue2 body}{fg=black, bg=blue!25} %
  \setbeamercolor{blue head}{fg=white, bg=black!30!blue!80} %
  \setbeamercolor{blue body}{fg=black, bg=gray!20} %
  \setbeamercolor{lightblue head}{fg=white, bg=blue!60} %
  \setbeamercolor{lightblue body}{fg=black, bg=blue!15} %
  \setbeamercolor{green head}{fg=white, bg=green!60!blue!150} %
  \setbeamercolor{green body}{fg=black, bg=green!25} %
  \setbeamercolor{red head}{fg=white, bg=black!30!red!90}
  \setbeamercolor{red body}{fg=black, bg=red!30}
  \setbeamercolor{pink body}{fg=black, bg=red!15}
  \setbeamercolor{gray head}{fg=white, bg=gray!60!blue!150} %
  \setbeamercolor{gray body}{fg=black, bg=gray!20} %
  
  \newenvironment{minip}[2]{\par\hspace{#1}\begin{minipage}{#2}}{\end{minipage}\par\medskip}  
  
  \newenvironment{winpink}{
    \begin{beamerboxesrounded}[lower=pink body, upper=red head,
      shadow=true] %
    } {\end{beamerboxesrounded}
  }

  \newenvironment{winblue}{
    \begin{beamerboxesrounded}[lower=blue body, upper=blue head,
      shadow=true] %
    } {\end{beamerboxesrounded}
  }
  
  \newenvironment{wingray}{
    \begin{beamerboxesrounded}[lower=gray body, upper=gray head,
      shadow=true] %
    } {\end{beamerboxesrounded}
  }

  \newenvironment{wingreengray}{
    \begin{beamerboxesrounded}[lower=gray body, upper=green head,
      shadow=true] %
    } {\end{beamerboxesrounded}
  }

  \newenvironment{wingreen}{
    \begin{beamerboxesrounded}[lower=green body, upper=green head,
      shadow=true] %
    } {\end{beamerboxesrounded}
  }

  \newenvironment{srcbox}{
    \begin{beamerboxesrounded}[lower=gray body, upper=gray head,
      shadow=true] %
    } {\end{beamerboxesrounded}\usebeamercolor{mine}}
  
  
  \newenvironment{psrcbox}[3]{
    \begin{minip}{#1}{#2}
      \begin{beamerboxesrounded}[lower=lightblue body, upper=gray head, shadow=true]{#3}
        \begingroup
      }%
      {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}


  \newenvironment{pagesrcbox}[3]{
    \par\medskip
    \begin{minip}{#1}{#2}
      \begin{beamerboxesrounded}[lower=lightblue body, upper=green head, shadow=true]{#3}
        \begingroup
      }%
      {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}
  
  \newenvironment{bluebox}[3]{
    \par\medskip
    \begin{minip}{#1}{#2}
      \begin{beamerboxesrounded}[lower=blue body, upper=blue2 head, shadow=true]{#3}
        \begingroup
      }%
      {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}
  

  % \newenvironment{greenbox}[3]{
  %   \par\medskip
  %   \begin{minip}{#1}{#2}
  %     \begin{beamerboxesrounded}[lower=green body, upper=green head, shadow=true]{#3}
  %       \begingroup
  %     }%
  %     {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}

  \newenvironment{pinkbox}[3]{
    \par\medskip
    \begin{minip}{#1}{#2}
      \begin{beamerboxesrounded}[lower=pink body, upper=red head, shadow=true]{#3}
        \begingroup
      }%
      {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}
  
  
  \def\@boxlower{}
  \def\@boxupper{}
  \newenvironment{wbox}[1]{
    \ifthenelse{\equal{#1}{blue}} %if 
    {\gdef\@boxlower{blue body}\gdef\@boxupper{blue head}} %then
    { %else
      \ifthenelse{\equal{#1}{pink}} %if
      {\gdef\@boxlower{pink body}\gdef\@boxupper{red head}} %then
      { %else
        \ifthenelse{\equal{#1}{blue2}} %if 
        {\gdef\@boxlower{blue2 body}\gdef\@boxupper{blue2 head}} %then
        { %else
          \ifthenelse{\equal{#1}{green}} % if
          {\gdef\@boxlower{green body}\gdef\@boxupper{green head}} %then
          {\gdef\@boxlower{gray body}\gdef\@boxupper{gray head}} %else
        }
      }
    }
    
    \begin{beamerboxesrounded}[lower=\@boxlower, upper=\@boxupper, shadow=true] %
    } {\end{beamerboxesrounded}\usebeamercolor{mine}}
  
  
  \newenvironment{pbox}[4]{
    \ifthenelse{\equal{#1}{blue}}{\gdef\@boxlower{blue body}\gdef\@boxupper{blue2 head}} %
    {\ifthenelse{\equal{#1}{pink}}{\gdef\@boxlower{pink body}\gdef\@boxupper{red head}} %
      {\ifthenelse{\equal{#1}{green}}{\gdef\@boxlower{green body}\gdef\@boxupper{green head}} %
        {\gdef\@boxlower{gray body}\gdef\@boxupper{gray head}}
      }
    }
    
    \par\medskip
    \begin{minip}{#2}{#3}
      \begin{beamerboxesrounded}[lower=\@boxlower, upper=\@boxupper, shadow=true]{#4}
        \begingroup
      }%
      {\endgroup\end{beamerboxesrounded}\end{minip}\usebeamercolor{mine}}
  



  %% \boxtobox e \fboxtobox costruiscono due box in orizzontale collegati da un
  %% freccia. \boxtobox  introduce una pausa fra la visualizzazione del primo box e
  %% la visualizzazione del secondo \fboxtobox non introduce pause.
  
  %% #1 - indentazione
  %% #2 - dimensione primo box
  %% #3 - testo primo box
  %% #4 - dimensione secondo box
  %% #5 - testo secondo box
  \newcommand{\boxtobox}[5]{  %%con pausa
    \par\hspace*{#1}\begin{tabular}{ccc}
      \begin{minipage}{#2}
        #3
      \end{minipage}
      &
      \pause
      \begin{minipage}[c]{4ex}
        \includegraphics[scale=.04,clip=true]{\beamerStyleDIR/redArrow.jpg}
      \end{minipage}
      &
      \begin{minipage}{#4}
        #5
      \end{minipage}
    \end{tabular}
    \par
  }
  
  \newcommand{\boxnextbox}[5]{%%con pausa
    \par\hspace*{#1}\begin{tabular}{cp{1ex}c}
      \begin{minipage}{#2}
        #3
      \end{minipage}
      &
      \pause
      &
      \begin{minipage}{#4}
        #5
      \end{minipage}
    \end{tabular}
    \par
  }
  
  \newcommand{\fboxtobox}[5]{  %%senza pausa
    \par\hspace*{#1}\begin{tabular}{ccc}
      \begin{minipage}{#2}
        #3
      \end{minipage}
      &
      \begin{minipage}[c]{2ex}
        \includegraphics[scale=.04,clip=true]{\beamerStyleDIR/redArrow.jpg}
      \end{minipage}
      &
      \begin{minipage}{#4}
        #5
      \end{minipage}
    \end{tabular}
    \par
  }
  
  %% #1 - indentazione
  %% #2 - dimensione primo box
  %% #3 - testo primo box
  %% #4 - spazio fra i box
  %% #4 - dimensione secondo box
  %% #5 - testo secondo box
  \newcommand{\boxnexttobox}[6]{  %%con pausa
    \par\hspace*{#1}\begin{tabular}{ccc}
      \begin{minipage}{#2}
        #3
      \end{minipage}
      &
      \pause
      \makebox[#4]{}
      % \begin{minipage}[c]{2ex}
      %   \includegraphics[scale=.04,clip=true]{redArrow.jpg}
      % \end{minipage}
      &
      \begin{minipage}{#5}
        #6
      \end{minipage}
    \end{tabular}
    \par
  }
  
}
  
