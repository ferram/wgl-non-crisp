\newtcolorbox{sommario}[1]{
  beforeafter skip=1\baselineskip,
  colbacktitle=white,
  top=0.2cm,
  bottom=0.2cm,
  halign lower=flush right,
  fonttitle=\bfseries,
  fontupper=\upshape\small,
  fontlower=\itshape\small,
  coltitle=black,
  center title,
  title={#1},
}

\newtcolorbox{tabella}[2][]{
  oversize,
  %%floatplacement=t,
  float,
  % colbacktitle=red!10!white,
  colbacktitle=tcbx_Blue_Medium,
  toptitle=0.2cm,
  bottomtitle=0.2cm,
  top=0.5cm,
  bottom=0.5cm,
  % boxsep=5mm,
  % leftupper=18cm,
  colframe=tcbx_Blue_Dark, 
  colback=tcbx_Blue_Bright,
  % colback=blue!10!white,coltitle=red!70!black,
  fonttitle=\bfseries,
  coltitle=black,
  center title,
  title={#2},
  #1
}

