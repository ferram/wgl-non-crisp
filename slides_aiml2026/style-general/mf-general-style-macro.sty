%% enumitem 
\RequirePackage{enumitem}
\setlist{leftmargin=*}
\setlist{nosep,itemsep=1ex,topsep=2ex,align=left}
\setitemize[2]{label=$\bullet$}
\setenumerate[1]{label=(\arabic*), ref=(\arabic*)}
\setenumerate[2]{leftmargin=*,label=(\alph*),ref=(\theenumi.\alph*)}
\setenumerate[3]{label=(\roman*)), ref=(\theenumii.\roman*)}
%\newenvironment{enuroman}{\begin{enumerate}[label=\tm{(\Roman*)},ref=\tm{(\arabic*)}]}
%{\end{enumerate}}
\newlist{enuroman}{enumerate}{1}
\setlist[enuroman]{label=\tm{(\Roman*)},ref=\tm{(\Roman*)}}

