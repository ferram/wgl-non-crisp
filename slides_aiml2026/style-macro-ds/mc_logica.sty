\newcommand{\TabA}[3]{
  \frac{\phantom{a}\stackrel{\textstyle #2}
    {\phantom{\scriptscriptstyle .}}\phantom{a}}
  {\stackrel{\phantom{\scriptscriptstyle .}}{\textstyle #3}}
  {\scriptstyle #1} 
}
\newcommand{\TabB}[4]{
  \frac{\phantom{aa}\stackrel{\textstyle #2}
    {\phantom{\scriptscriptstyle .}}\phantom{aa}}
  {\stackrel{\phantom{\scriptscriptstyle .}}{\textstyle #3~\left|~#4\right.}}
  {\scriptstyle #1} 
}



