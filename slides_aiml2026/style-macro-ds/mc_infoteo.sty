%%%MODIFICHE PER DERIVAZIONI
\newlength{\lungtop}\newlength{\lungbottom}\newlength{\lungmiddle}
\newcommand{\twoargumentarrow}[2]{
  \settowidth{\lungtop}{$\scriptstyle #1$}
  \settowidth{\lungbottom}{$\scriptscriptstyle #2$}
  \settowidth{\lungmiddle}{$\Rightarrow$}
  \Rightarrow\hspace{-\lungmiddle}\hspace{-0.3ex}
  \raisebox{1.1ex}{$\scriptstyle #1$}\hspace{-\lungtop}\hspace{-0.3ex}
  \raisebox{-0.75ex}{$\scriptscriptstyle #2$}\hspace{-\lungbottom}
  \hspace{\lungmiddle}
  %\ifthenelse{\lungtop>\lungbottom}{\hspace{-\lungbottom}\hspace{\lungtop}}{}
  }
%%\def\ders{\mathrel{\mbox{$\twoargumentarrow{*}{}$}}}
\def\lmder{\mathrel{\mbox{$\twoargumentarrow{}{lm}$}}}
\def\rmder{\mathrel{\mbox{$\twoargumentarrow{}{rm}$}}}
\def\lmders{\mathrel{\mbox{$\twoargumentarrow{*}{lm}$}}}
\def\rmders{\mathrel{\mbox{$\twoargumentarrow{*}{rm}$}}}
